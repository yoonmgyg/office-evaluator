FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl unzip wget && rm -rf /var/lib/apt/lists/*

RUN wget -qO /app/treasury_bulletins_transformed.zip https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/treasury_bulletins_parsed/transformed/treasury_bulletins_transformed.zip

RUN pip install --no-cache-dir \
    "a2a-sdk[http-server]>=0.3.20" \
    "httpx>=0.28.1" \
    "pydantic>=2.11.0" \
    "python-dotenv>=1.1.1" \
    "uvicorn>=0.38.0" \
    "openai>=1.50.0" \
    "anthropic>=0.40.0" \
    "pandas>=2.0.0" \
    "requests>=2.31.0"

COPY participant/src/ ./

ENTRYPOINT ["python", "server.py"]
CMD ["--host", "0.0.0.0", "--port", "9019"]
EXPOSE 9019
